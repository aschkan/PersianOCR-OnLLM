# Only relevant when the frontend is installed on the server (proxy --build); the
# committed build/ is served otherwise. Same rationale as the server's .npmrc:
# tolerate a flaky registry.npmjs.org connection instead of failing on one slow
# tarball.
fetch-retries=8
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=600000
audit=false
fund=false

# If npmjs.org stays unreachable and you have a faster/closer mirror:
# registry=https://registry.npmmirror.com/
