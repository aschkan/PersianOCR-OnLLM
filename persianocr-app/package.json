{
  "name": "persianocr-app",
  "version": "1.0.0",
  "private": true,
  "description": "PersianOCR-OnLLM — React frontend for Persian receipt OCR on a local vision LLM.",
  "dependencies": {
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "remark-gfm": "^4.0.1"
  },
  "scripts": {
    "css": "tailwindcss -i src/styles.css -o src/index.css",
    "css:min": "tailwindcss -i src/styles.css -o src/index.css --minify",
    "prestart": "npm run css",
    "start": "react-scripts start",
    "prebuild": "npm run css:min",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "daisyui": "^4.12.24",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19"
  },
  "proxy": "http://localhost:5004"
}
