# ─────────────────────────────────────────────────────────────────────────────
# PersianOCR-OnLLM server — REAL config (committed on purpose; adjust freely).
# Under the reverse-proxy orchestrator, env/persianocr.env (in the proxy repo)
# plus the forced BEHIND_PROXY/APP_PORT/HOST/NODE_ENV take precedence over this
# file — dotenv never overrides variables that are already set. This file is
# what standalone/dev runs use.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5004
MONGO_URI=mongodb://127.0.0.1:27017/persianocr
TRUST_PROXY_HOPS=1
RECLAIM_PORT=true

# ── Vision LLM (LM Studio on the LAN GPU/Windows box) ─────────────────────────
OCR_AI_URL=http://192.168.11.165:1234/v1
OCR_AI_MODEL=gemma-3-4b-it
OCR_AI_KEY=
OCR_TIMEOUT_MS=180000
OCR_MAX_TOKENS=4096
OCR_TEMPERATURE=0.1
OCR_IMAGE_MODE=auto

# ── Multi-pass + Tesseract grounding ──────────────────────────────────────────
OCR_PASSES=1
OCR_DRAFT_TEMP=0.35
OCR_TESSERACT=auto
OCR_TESSERACT_LANG=fas+eng
OCR_TESSERACT_PSM=6
OCR_PREPROCESS=auto

# ── Adaptive self-verifying extraction ────────────────────────────────────────
OCR_VERIFY=true
OCR_ADAPTIVE=true
OCR_FIX_ROUNDS=2
OCR_REF_MODE=auto
OCR_CROP_RETRY=true
OCR_ENHANCE_FOR_LLM=true
OCR_QUALITY_MIN_DIM=640
OCR_QUALITY_MIN_STDDEV=0.10

# ── Image size guard (browser compresses to 1 MB too) ─────────────────────────
OCR_LLM_MAX_MB=1
OCR_LLM_MAX_DIM=2048

# ── Uploads / CORS ────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=20
UPLOAD_DIR=uploads
# CORS_ORIGINS=https://persianocr.ir
