# ─────────────────────────────────────────────────────────────────────────────
# PersianOCR-OnLLM server — environment configuration
# Copy to `.env` and fill in. Never commit `.env` (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Dev / plain-HTTP port (also the default APP_PORT when not behind the proxy).
PORT=5004
MONGO_URI=mongodb://127.0.0.1:27017/persianocr

# ── Reverse-proxy upstream mode ───────────────────────────────────────────────
# When the platform reverse proxy runs this app, it injects:
#   BEHIND_PROXY=true  HOST=127.0.0.1  APP_PORT=8084  NODE_ENV=production
# Leave these unset for standalone local dev.
# BEHIND_PROXY=true
# HOST=127.0.0.1
# APP_PORT=8084
# Number of proxy hops in front of this app (for correct req.ip / rate limiting).
TRUST_PROXY_HOPS=1

# On startup, if APP_PORT is already held by a stale/previous instance, kill the
# holder and bind anyway instead of dying with EADDRINUSE. true (default) | false.
RECLAIM_PORT=true

# ── Vision LLM (OCR) — LM Studio on the LAN GPU/Windows box ────────────────────
# The receipt image is sent to an OpenAI-compatible /chat/completions endpoint
# as a multimodal message (text prompt + base64 image_url). LM Studio exposes
# this at http://<host>:1234/v1. gemma-3-4b-it is a vision model and reads the
# image directly. Point OCR_AI_URL at your LM Studio machine (NOT this server —
# LM Studio runs on a separate Windows box on the network).
OCR_AI_URL=http://192.168.11.165:1234/v1
OCR_AI_MODEL=gemma-3-4b-it
# Optional bearer key if you put an auth proxy in front of LM Studio. Usually empty.
OCR_AI_KEY=
# How long to wait for the model (ms). Handwriting / big tables can be slow.
OCR_TIMEOUT_MS=180000
# Generation controls. Low temperature keeps the transcription faithful.
OCR_MAX_TOKENS=4096
OCR_TEMPERATURE=0.1
# How the image is encoded in the request. Some LM Studio / llama.cpp builds want
# a full data-URL, others reject it and demand the RAW base64 ("'url' field must
# be a base64 encoded image."). 'auto' (default) tries data-URL then falls back to
# raw base64 and remembers what worked. Force it with dataurl | base64.
OCR_IMAGE_MODE=auto

# ── Accuracy: multi-pass "self-consistency" OCR ───────────────────────────────
# Small models (e.g. gemma-3-4b) sometimes misread a digit or drop a trailing
# zero on Rial amounts. OCR_PASSES>1 runs the transcription that many times, then
# reconciles the attempts against the image in a final proof-reading pass (which
# is what streams to the user). Much more accurate on tricky/print-heavy receipts,
# but N+1× slower. 1 = off (single pass). 2–3 is a good sweet spot.
OCR_PASSES=1
# Temperature for the draft passes (a little diversity helps the reconciliation
# spot disagreements). The reconciliation pass itself is always deterministic.
OCR_DRAFT_TEMP=0.35

# ── Reference OCR (Tesseract) — grounds the model on exact DIGITS ──────────────
# A small vision model reliably misreads big Persian amounts (۲۰٬۰۰۰٬۰۰۰ → ۲۰٬۰۰۰)
# the SAME way every pass, so reconciliation can't fix it. Tesseract is good at
# digits; when installed, its text is passed to the model as a reference so it
# copies numbers/codes correctly. Auto-detected; force with true|false.
#   sudo apt install tesseract-ocr tesseract-ocr-fas imagemagick
OCR_TESSERACT=auto
OCR_TESSERACT_LANG=fas+eng
# Page-segmentation mode (6 = a uniform block of text; good for receipts).
OCR_TESSERACT_PSM=6
# Pre-process the image with ImageMagick before OCR (grayscale/upscale/normalise)
# — big accuracy win on faint thermal receipts. auto = on when `convert` exists.
OCR_PREPROCESS=auto
# TESSERACT_BIN=tesseract
# IMAGEMAGICK_BIN=convert

# ── Uploads ───────────────────────────────────────────────────────────────────
# Max accepted image size (MB) and where original images are stored on disk.
UPLOAD_MAX_MB=20
UPLOAD_DIR=uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allow-list for production. Empty → reflect any origin (dev).
# CORS_ORIGINS=https://persianocr.ir
