# ─────────────────────────────────────────────────────────────────────────────
# PersianOCR-OnLLM server — environment configuration
# Copy to `.env` and fill in. Never commit `.env` (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Dev / plain-HTTP port (also the default APP_PORT when not behind the proxy).
PORT=5004
MONGO_URI=mongodb://127.0.0.1:27017/persianocr

# ── Reverse-proxy upstream mode ───────────────────────────────────────────────
# When the platform reverse proxy runs this app, it injects:
#   BEHIND_PROXY=true  HOST=127.0.0.1  APP_PORT=8084  NODE_ENV=production
# Leave these unset for standalone local dev.
# BEHIND_PROXY=true
# HOST=127.0.0.1
# APP_PORT=8084
# Number of proxy hops in front of this app (for correct req.ip / rate limiting).
TRUST_PROXY_HOPS=1

# ── Vision LLM (OCR) — LM Studio on the LAN GPU/Windows box ────────────────────
# The receipt image is sent to an OpenAI-compatible /chat/completions endpoint
# as a multimodal message (text prompt + base64 image_url). LM Studio exposes
# this at http://<host>:1234/v1. gemma-3-4b-it is a vision model and reads the
# image directly. Point OCR_AI_URL at your LM Studio machine (NOT this server —
# LM Studio runs on a separate Windows box on the network).
OCR_AI_URL=http://192.168.11.165:1234/v1
OCR_AI_MODEL=gemma-3-4b-it
# Optional bearer key if you put an auth proxy in front of LM Studio. Usually empty.
OCR_AI_KEY=
# How long to wait for the model (ms). Handwriting / big tables can be slow.
OCR_TIMEOUT_MS=180000
# Generation controls. Low temperature keeps the transcription faithful.
OCR_MAX_TOKENS=4096
OCR_TEMPERATURE=0.1
# How the image is encoded in the request. Some LM Studio / llama.cpp builds want
# a full data-URL, others reject it and demand the RAW base64 ("'url' field must
# be a base64 encoded image."). 'auto' (default) tries data-URL then falls back to
# raw base64 and remembers what worked. Force it with dataurl | base64.
OCR_IMAGE_MODE=auto

# ── Uploads ───────────────────────────────────────────────────────────────────
# Max accepted image size (MB) and where original images are stored on disk.
UPLOAD_MAX_MB=20
UPLOAD_DIR=uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allow-list for production. Empty → reflect any origin (dev).
# CORS_ORIGINS=https://persianocr.ir
