# The deploy server can have flaky access to registry.npmjs.org (npm ci was
# timing out on individual tarballs, e.g. ETIMEDOUT fetching a .tgz). npm's
# defaults are only 2 retries / 60s, so one slow download fails the whole
# install. Retry hard and give each fetch plenty of time so an intermittent
# connection still completes. Skipping audit/fund also cuts extra round-trips.
fetch-retries=8
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=600000
audit=false
fund=false

# If npmjs.org stays unreachable and you have a faster/closer mirror, set it
# here (uncomment + edit) — applies to this app's installs only:
# registry=https://registry.npmmirror.com/
